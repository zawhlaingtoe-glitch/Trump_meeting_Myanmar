<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Welcome | Zaw Hlaing Trump's Meeting</title>
    <link rel="stylesheet" href="/style.css">
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@300;400;700&display=swap" rel="stylesheet">
</head>

<body>
    <div class="mesh-gradient"></div>

    <div class="login-wrapper">
        <header class="hero-section">
            <h1 class="glow-text">Welcome from Zaw Hlaing Trump's Meeting</h1>
            <p class="subtitle">Secure, high-definition video collaboration.</p>
        </header>

        <div class="glass-card">
            <form action="/login" method="POST">
                <input type="text" name="username" placeholder="Username" required>
                <input type="password" name="password" placeholder="Password" required>
                <button type="submit" class="glass-btn">Enter Meeting</button>
            </form>
            <div class="auth-footer">
                <p>Don't have an account? <a href="/signup">Sign Up</a></p>
            </div>
        </div>
    </div>
</body>

</html>