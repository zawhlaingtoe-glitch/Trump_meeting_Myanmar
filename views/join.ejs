<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Join Meeting</title>
    <link rel="stylesheet" href="/style.css">
    <script src="https://kit.fontawesome.com/c9c589714d.js" crossorigin="anonymous"></script>
</head>

<body>
    <div class="mesh-gradient"></div>
    <div class="login-wrapper">
        <div class="glass-card">
            <h2 class="glow-text" style="font-size: 2rem;">Join Meeting</h2>
            <form action="/join-room" method="POST">
                <input type="text" name="roomId" placeholder="Enter Room ID" required>
                <button type="submit" class="glass-btn" style="width: 100%;">Join Now</button>
            </form>
            <div style="margin-top: 20px;">
                <a href="/dashboard" style="color: #94a3b8; text-decoration: none;">← Back to Dashboard</a>
            </div>
        </div>
    </div>
</body>

</html>