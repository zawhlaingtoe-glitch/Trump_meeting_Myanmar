<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Join | Zaw Hlaing Trump's Meeting</title>
    <link rel="stylesheet" href="/style.css">
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@300;400;700&display=swap" rel="stylesheet">
    <script src="https://kit.fontawesome.com/c9c589714d.js" crossorigin="anonymous"></script>
</head>

<body>
    <div class="mesh-gradient"></div>

    <div class="login-wrapper">
        <header class="hero-section">
            <h1 class="glow-text">Join Meeting</h1>
            <p class="subtitle">Zaw Hlaing Trump's Meeting Network</p>
        </header>

        <div class="glass-card">
            <form action="/join-room" method="POST">
                <div class="input-container">
                    <i class="fas fa-hashtag"></i>
                    <input type="text" name="roomId" placeholder="Enter Room ID" required autocomplete="off">
                </div>
                <button type="submit" class="glass-btn">
                    <i class="fas fa-sign-in-alt"></i> Join Now
                </button>
            </form>

            <div class="auth-footer">
                <a href="/dashboard" class="back-link">
                    <i class="fas fa-arrow-left"></i> Back to Dashboard
                </a>
            </div>
        </div>
    </div>
</body>

</html>