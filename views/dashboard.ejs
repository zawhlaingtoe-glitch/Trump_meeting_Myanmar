<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Dashboard</title>
    <link rel="stylesheet" href="/style.css">
    <script src="https://kit.fontawesome.com/c9c589714d.js" crossorigin="anonymous"></script>
</head>

<body>
    <div class="mesh-gradient"></div>
    <div class="login-wrapper">
        <div class="glass-card" style="max-width: 500px;">
            <div class="user-profile">
                <i class="fas fa-user-circle" style="font-size: 3rem; color: var(--accent);"></i>
                <h2>Hello,
                    <%= userName %>
                </h2>
            </div>
            <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 15px; margin: 25px 0;">
                <a href="/host" class="glass-btn" style="text-decoration: none; text-align: center;">
                    <i class="fas fa-plus"></i> Host
                </a>
                <a href="/join" class="glass-btn" style="text-decoration: none; text-align: center; background: rgba(255,255,255,0.1);">
                    <i class="fas fa-door-open"></i> Join
                </a>
            </div>
            <a href="/" style="color: #ef4444; text-decoration: none; font-size: 0.9rem;">Sign Out</a>
        </div>
    </div>
</body>

</html>