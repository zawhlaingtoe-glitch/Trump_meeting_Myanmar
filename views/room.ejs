<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Meeting Room</title>
    <link rel="stylesheet" href="/style.css">
    <script src="https://kit.fontawesome.com/c9c589714d.js" crossorigin="anonymous"></script>
    <script src="/socket.io/socket.io.js"></script>
    <script>
        const ROOM_ID = "<%= roomId %>";
        const USER_NAME = "<%= userName %>";
    </script>
</head>

<body class="room-page">
    <div class="mesh-gradient"></div>

    <div id="preview-container" class="glass-overlay">
        <div class="glass-card preview-box">
            <h2 class="glow-text">Check Your Setup</h2>
            <video id="local-preview" muted></video>
            <button onclick="startMeeting()" class="glass-btn primary">Join Meeting Now</button>
        </div>
    </div>

    <div class="glass-nav">
        <div class="room-info">
            <span class="live-indicator"></span>
            <h2>
                <%= roomId.substring(0,8) %>...</h2>
        </div>
        <button onclick="copyLink()" class="glass-btn sm"><i class="fas fa-link"></i> Copy Link</button>
    </div>

    <div id="video-grid"></div>

    <div id="chat-sidebar" class="glass-sidebar">
        <div class="chat-header">
            <h3>Room Chat</h3><button onclick="toggleChat()">&times;</button></div>
        <div id="chat-messages"></div>
        <div class="chat-input-area">
            <input type="text" id="chat-input" placeholder="Type message...">
            <button id="send-btn"><i class="fas fa-paper-plane"></i></button>
        </div>
    </div>

    <div class="floating-controls">
        <div class="glass-dock">
            <button id="mute-btn" class="dock-item"><i class="fas fa-microphone"></i></button>
            <button id="camera-btn" class="dock-item"><i class="fas fa-video"></i></button>
            <button id="screen-btn" class="dock-item"><i class="fas fa-desktop"></i></button>
            <button id="record-btn" class="dock-item"><i class="fas fa-circle"></i></button>
            <button onclick="toggleChat()" class="dock-item"><i class="fas fa-comment"></i></button>
            <button onclick="leaveMeeting()" class="dock-item leave"><i class="fas fa-phone"></i></button>
        </div>
    </div>

    <script src="/script.js"></script>
</body>

</html>