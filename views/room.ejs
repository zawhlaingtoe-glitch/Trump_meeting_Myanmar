<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Meeting Room</title>
    <link rel="stylesheet" href="/style.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <script src="/socket.io/socket.io.js"></script>
    <script src="https://unpkg.com/peerjs@1.4.7/dist/peerjs.min.js"></script>
    <script>
        const ROOM_ID = "<%= roomId %>";
        const USER_NAME = "<%= typeof userName !== 'undefined' ? userName : 'Guest' %>";
    </script>
</head>

<body class="room-page">
    <div class="mesh-gradient"></div>

    <div class="glass-nav">
        <div class="room-info">
            <span class="live-indicator"></span>
            <h2>Zaw Hlaing Trump's Meeting</h2>
        </div>
        <button onclick="copyLink()" class="glass-btn sm">
            <i class="fas fa-link"></i> Copy Link
        </button>
    </div>

    <div id="video-grid"></div>

    <div class="floating-controls">
        <div class="glass-dock">
            <button id="mute-btn" class="dock-item" title="Mute/Unmute">
                <i class="fas fa-microphone"></i>
            </button>
            <button id="camera-btn" class="dock-item" title="Start/Stop Video">
                <i class="fas fa-video"></i>
            </button>
            <button id="screen-btn" class="dock-item" title="Share Screen">
                <i class="fas fa-desktop"></i>
            </button>
            <button onclick="leaveMeeting()" class="dock-item leave" title="End Call">
                <i class="fas fa-phone"></i>
            </button>
        </div>
    </div>

    <script src="/script.js"></script>
</body>

</html>