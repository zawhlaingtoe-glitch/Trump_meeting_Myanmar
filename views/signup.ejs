<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Sign Up</title>
    <link rel="stylesheet" href="/style.css">
</head>

<body>
    <div class="mesh-gradient"></div>
    <div class="login-wrapper">
        <div class="glass-card">
            <h1 class="glow-text" style="font-size: 2.5rem;">Create Account</h1>
            <form action="/signup" method="POST">
                <input type="text" name="username" placeholder="Choose Username" required>
                <input type="password" name="password" placeholder="Choose Password" required>
                <button type="submit" class="glass-btn">Create Account</button>
            </form>
            <div style="margin-top: 20px; font-size: 0.9rem; color: #94a3b8;">
                Already have an account? <a href="/" style="color: var(--accent);">Login</a>
            </div>
        </div>
    </div>
</body>

</html>s