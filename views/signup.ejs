<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Join the Meeting | Sign Up</title>
    <link rel="stylesheet" href="/style.css">
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@300;400;700&display=swap" rel="stylesheet">
</head>

<body class="glass-bg">
    <div class="mesh-gradient"></div>
    <div class="login-wrapper">
        <header class="hero-section">
            <h1 class="glow-text">Create Account</h1>
            <p class="subtitle">Join Zaw Hlaing Trump's Meeting network.</p>
        </header>

        <div class="glass-card login-box">
            <form action="/signup" method="POST">
                <input type="text" name="username" placeholder="Choose Username" required>
                <input type="password" name="password" placeholder="Create Password" required>
                <button type="submit" class="glass-btn primary">Register Now</button>
            </form>
            <div class="auth-footer">
                <p>Already a member? <a href="/">Login</a></p>
            </div>
        </div>
    </div>
</body>

</html>